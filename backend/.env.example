# ═══════════════════════════════════════════════════════════
#  .env.example — Copy to .env and fill in your real values
#  NEVER commit .env to git — add it to .gitignore!
# ═══════════════════════════════════════════════════════════

# ── Database (from your PostgreSQL host, e.g. Neon / Supabase / Railway) ──
DATABASE_URL=jdbc:postgresql://localhost:5432/chatapp
DB_USERNAME=postgres
DB_PASSWORD=your_db_password_here

# ── JWT Secret (use a long random string, min 32 chars) ──────────────────
JWT_SECRET=change_me_to_a_very_long_random_secret_string_at_least_32_chars

# ── CORS — your frontend domain (Netlify / Vercel / custom domain) ───────
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# ── Spring Profile ────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod
